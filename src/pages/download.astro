---
import BaseLayout from '../layouts/BaseLayout.astro';
import fallback from '../data/release-fallback.json';
import { validateUpdateJson, type UpdateJson } from '../scripts/release-info';

// Build-time fetch of update.json. On any failure (network, 404, malformed,
// schemaVersion mismatch), fall back to the committed release-fallback.json
// so the page always has SOMETHING valid to render at first paint.
//
// The resolved `updateInfo` is the SINGLE source of truth for both:
//   1. Initial HTML rendered by Astro (the JSX expressions below).
//   2. Embedded `window.__SGH_UPDATE__` baseline (the inline script at end).
// This guarantees those two never disagree about first-paint state.
//
// See openspec/specs/landing-site/spec.md (V3 repo) — scenario "Fallback content
// is current as of last site build" + sister scenarios for failure modes.

let updateInfo: UpdateJson;
try {
  const res = await fetch('https://dl.smartgalleryhub.com/latest/update.json', {
    signal: AbortSignal.timeout(5000),
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const parsed = await res.json();
  const validated = validateUpdateJson(parsed);
  if (!validated) throw new Error('schema validation failed');
  updateInfo = validated;
} catch (err) {
  // eslint-disable-next-line no-console
  console.warn('[sgh build-time] update.json fetch failed; using release-fallback.json:', err);
  // Fallback file is committed and validated by tests — safe to cast.
  updateInfo = fallback as UpdateJson;
}

const DL_BASE = 'https://dl.smartgalleryhub.com';
const WINDOWS_URL = `${DL_BASE}/latest/SGH-Setup.exe`;
const MAC_URL = `${DL_BASE}/latest/SGH-universal.dmg`;
---

<BaseLayout title="Download Smart Gallery Hub" description="Download Smart Gallery Hub for Windows and Mac (Intel + Apple Silicon).">
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 pt-20 pb-8 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight">
      Download Smart Gallery Hub
    </h1>
    <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
      Version <span class="font-mono" data-sgh-version>v{updateInfo.version}</span> · runs locally on your machine · 30-day free trial, no credit card required.
    </p>
  </section>

  <!-- What's new (highlights from update.json, fallback to maintenance-release copy) -->
  <section class="max-w-4xl mx-auto px-4 pb-8">
    <div class="rounded-xl bg-gray-50 border border-gray-200 p-6">
      <h2 class="font-semibold text-lg text-gray-900">What's new</h2>
      <ul data-sgh-highlights class="mt-3 list-disc pl-5 space-y-1 text-sm text-gray-700">
        {updateInfo.highlights.length === 0 ? (
          <span>
            No new features in this release — bug fixes and stability improvements. See <a href={updateInfo.fullChangelog} target="_blank" rel="noopener noreferrer" class="underline text-brand-600 hover:text-brand-700">full changelog</a> for details.
          </span>
        ) : (
          updateInfo.highlights.map((line) => <li>{line}</li>)
        )}
      </ul>
    </div>
  </section>

  <!-- Download cards: Windows + Mac Universal (consolidated from previous 3-card layout) -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <!-- Windows -->
      <a href={WINDOWS_URL} class="rounded-xl border border-gray-200 bg-white p-6 flex flex-col hover:border-brand-300 hover:shadow-md transition-all">
        <div class="text-4xl mb-3" aria-hidden="true">&#x1FA9F;</div>
        <h2 class="font-semibold text-lg text-gray-900">Windows</h2>
        <p class="mt-1 text-sm text-gray-600">64-bit · Windows 10 or later</p>
        <p class="mt-1 text-xs text-gray-500">~151 MB · NSIS installer</p>
        <div class="mt-auto pt-6">
          <span class="inline-flex items-center justify-center w-full px-4 py-2.5 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
            Download for Windows
          </span>
        </div>
      </a>

      <!-- Mac Universal (Intel + Apple Silicon) -->
      <a href={MAC_URL} class="rounded-xl border border-gray-200 bg-white p-6 flex flex-col hover:border-brand-300 hover:shadow-md transition-all">
        <div class="text-4xl mb-3" aria-hidden="true">&#x1F34F;</div>
        <h2 class="font-semibold text-lg text-gray-900">Mac · Universal binary</h2>
        <p class="mt-1 text-sm text-gray-600">Intel and Apple Silicon · macOS 12 or later</p>
        <p class="mt-1 text-xs text-gray-500">~422 MB · DMG</p>
        <div class="mt-auto pt-6">
          <span class="inline-flex items-center justify-center w-full px-4 py-2.5 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
            Download for Mac
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- Mac unsigned warning -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-900">
      <strong>First time on Mac?</strong> macOS will say <em>"&ldquo;SGH&rdquo; can't be opened because Apple cannot check it for malicious software"</em>. Right-click the app in Finder → <strong>Open</strong> → confirm. You only need to do this once. <span class="opacity-75">(Apple Developer signing is on the roadmap once revenue covers the cost.)</span>
    </div>
  </section>

  <!-- System requirements -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="rounded-xl bg-gray-50 border border-gray-200 p-6">
      <h2 class="font-semibold text-lg text-gray-900">System requirements</h2>
      <ul class="mt-4 space-y-2 text-sm text-gray-600">
        <li><strong class="text-gray-900">RAM:</strong> 8&nbsp;GB minimum, 16&nbsp;GB recommended for large libraries</li>
        <li><strong class="text-gray-900">Disk:</strong> 2&nbsp;GB for the app, plus space for your photo library</li>
        <li><strong class="text-gray-900">AI processing:</strong> Runs locally via Ollama or a compatible OpenAI-format endpoint. GPU optional but recommended.</li>
        <li><strong class="text-gray-900">Internet:</strong> Required only for license activation and submission to stock agencies.</li>
      </ul>
    </div>
  </section>

  <!-- Support -->
  <section class="max-w-4xl mx-auto px-4 pb-20 text-center">
    <p class="text-sm text-gray-500">
      Having trouble installing? Email
      <a href="mailto:support@smartgalleryhub.com" class="text-brand-600 hover:text-brand-700 underline">support@smartgalleryhub.com</a>
    </p>
  </section>

  <!-- Build-time embed: baseline values for runtime fetch handler to compare against -->
  <script is:inline define:vars={{ embeddedUpdate: updateInfo }}>
    window.__SGH_UPDATE__ = embeddedUpdate;
  </script>

  <!-- Runtime fetch: try live update.json, validate, apply on success -->
  <script>
    import { validateUpdateJson, applyUpdate } from '../scripts/release-info';

    declare global {
      interface Window {
        __SGH_UPDATE__: unknown;
      }
    }

    void (async () => {
      try {
        const res = await fetch('https://dl.smartgalleryhub.com/latest/update.json', {
          cache: 'no-store',
        });
        if (!res.ok) {
          // eslint-disable-next-line no-console
          console.warn('[sgh] update.json fetch returned non-200; using embedded fallback', res.status);
          return;
        }
        const parsed = await res.json();
        const validated = validateUpdateJson(parsed);
        if (!validated) {
          // eslint-disable-next-line no-console
          console.warn('[sgh] update.json schema mismatch — using embedded fallback');
          return;
        }
        applyUpdate(validated);
        // eslint-disable-next-line no-console
        console.info(`[sgh] update.json fetch ok, version=${validated.version}`);
      } catch (err) {
        // eslint-disable-next-line no-console
        console.warn('[sgh] update.json fetch failed — using embedded fallback', err);
      }
    })();
  </script>
</BaseLayout>
