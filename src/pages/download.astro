---
import BaseLayout from '../layouts/BaseLayout.astro';

const VERSION = '0.1.0';
const DL_BASE = 'https://dl.smartgalleryhub.com';
const WINDOWS_URL = `${DL_BASE}/latest/SGH-Setup.exe`;
const MAC_ARM64_URL = `${DL_BASE}/latest/SGH-arm64.dmg`;
const MAC_X64_URL = `${DL_BASE}/latest/SGH-x64.dmg`;
---

<BaseLayout title="Download Smart Gallery Hub" description="Download Smart Gallery Hub for Windows, Mac Intel, and Apple Silicon.">
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 pt-20 pb-8 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight">
      Download Smart Gallery Hub
    </h1>
    <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
      Version <span class="font-mono">{VERSION}</span> · runs locally on your machine · 30-day free trial, no credit card required.
    </p>
  </section>

  <!-- Download cards -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <!-- Windows -->
      <a href={WINDOWS_URL} class="rounded-xl border border-gray-200 bg-white p-6 flex flex-col hover:border-brand-300 hover:shadow-md transition-all">
        <div class="text-4xl mb-3" aria-hidden="true">&#x1FA9F;</div>
        <h2 class="font-semibold text-lg text-gray-900">Windows</h2>
        <p class="mt-1 text-sm text-gray-600">64-bit · Windows 10 or later</p>
        <p class="mt-1 text-xs text-gray-500">~149 MB · NSIS installer</p>
        <div class="mt-auto pt-6">
          <span class="inline-flex items-center justify-center w-full px-4 py-2.5 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
            Download for Windows
          </span>
        </div>
      </a>

      <!-- Mac Apple Silicon -->
      <a href={MAC_ARM64_URL} class="rounded-xl border border-gray-200 bg-white p-6 flex flex-col hover:border-brand-300 hover:shadow-md transition-all">
        <div class="text-4xl mb-3" aria-hidden="true">&#x1F34F;</div>
        <h2 class="font-semibold text-lg text-gray-900">Mac (Apple Silicon)</h2>
        <p class="mt-1 text-sm text-gray-600">M1/M2/M3/M4 · macOS 12 or later</p>
        <p class="mt-1 text-xs text-gray-500">~160 MB · DMG</p>
        <div class="mt-auto pt-6">
          <span class="inline-flex items-center justify-center w-full px-4 py-2.5 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
            Download for Mac
          </span>
        </div>
      </a>

      <!-- Mac Intel -->
      <a href={MAC_X64_URL} class="rounded-xl border border-gray-200 bg-white p-6 flex flex-col hover:border-brand-300 hover:shadow-md transition-all">
        <div class="text-4xl mb-3" aria-hidden="true">&#x1F5A5;&#xFE0F;</div>
        <h2 class="font-semibold text-lg text-gray-900">Mac (Intel)</h2>
        <p class="mt-1 text-sm text-gray-600">x64 · macOS 12 or later</p>
        <p class="mt-1 text-xs text-gray-500">~160 MB · DMG</p>
        <div class="mt-auto pt-6">
          <span class="inline-flex items-center justify-center w-full px-4 py-2.5 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700 transition-colors">
            Download for Mac (Intel)
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- Mac unsigned warning -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-900">
      <strong>First time on Mac?</strong> macOS will say <em>"&ldquo;SGH&rdquo; can't be opened because Apple cannot check it for malicious software"</em>. Right-click the app in Finder → <strong>Open</strong> → confirm. You only need to do this once. (We're working on Apple Developer signing.)
    </div>
  </section>

  <!-- System requirements -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="rounded-xl bg-gray-50 border border-gray-200 p-6">
      <h2 class="font-semibold text-lg text-gray-900">System requirements</h2>
      <ul class="mt-4 space-y-2 text-sm text-gray-600">
        <li><strong class="text-gray-900">RAM:</strong> 8&nbsp;GB minimum, 16&nbsp;GB recommended for large libraries</li>
        <li><strong class="text-gray-900">Disk:</strong> 2&nbsp;GB for the app, plus space for your photo library</li>
        <li><strong class="text-gray-900">AI processing:</strong> Runs locally via Ollama or a compatible OpenAI-format endpoint. GPU optional but recommended.</li>
        <li><strong class="text-gray-900">Internet:</strong> Required only for license activation and submission to stock agencies.</li>
      </ul>
    </div>
  </section>

  <!-- Support -->
  <section class="max-w-4xl mx-auto px-4 pb-20 text-center">
    <p class="text-sm text-gray-500">
      Having trouble installing? Email
      <a href="mailto:support@smartgalleryhub.com" class="text-brand-600 hover:text-brand-700 underline">support@smartgalleryhub.com</a>
    </p>
  </section>
</BaseLayout>
