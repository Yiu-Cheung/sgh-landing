---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 pt-20 pb-16 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight">
      AI metadata for your<br />
      <span class="text-brand-600">entire photo library.</span>
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto">
      Smart Gallery Hub generates titles, descriptions, and keywords for thousands of photos and videos — then organizes, tags, and exports them in the format you need.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://ms-contributor.lemonsqueezy.com/checkout/buy/42b7760e-cd5c-49df-9d8f-f68ebe05e074"
        class="bg-brand-600 text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-brand-700 transition-colors shadow-lg shadow-brand-600/25"
      >
        Try Pro Free for 30 Days
      </a>
      <a
        href="#features"
        class="text-brand-600 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-brand-50 transition-colors"
      >
        Learn more &darr;
      </a>
    </div>
    <div class="mt-16 rounded-xl overflow-hidden shadow-2xl border border-gray-200 max-w-4xl mx-auto">
      <img src="/main.png" alt="Smart Gallery Hub workspace showing image library with metadata panel and content type folders" class="w-full" loading="eager" />
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="bg-gray-50 py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-gray-900">A complete metadata workflow</h2>
      <p class="mt-4 text-center text-gray-600 max-w-xl mx-auto">
        From raw folder to tagged, organized, export-ready library — in minutes, not hours.
      </p>

      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center text-brand-600 text-xl mb-4">&#x1F916;</div>
          <h3 class="font-semibold text-gray-900">AI Metadata Generation</h3>
          <p class="mt-2 text-sm text-gray-600">Point at a folder. Titles, descriptions, and keywords are generated by AI running on your own hardware.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center text-brand-600 text-xl mb-4">&#x1F4C1;</div>
          <h3 class="font-semibold text-gray-900">Content-Type Organization</h3>
          <p class="mt-2 text-sm text-gray-600">Sort photos and videos into Default, Commercial, Editorial, AI Generated, or Illustration — each with the right metadata fields.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center text-brand-600 text-xl mb-4">&#x1F4DD;</div>
          <h3 class="font-semibold text-gray-900">Keyword Management</h3>
          <p class="mt-2 text-sm text-gray-600">Review, edit, and refine AI-generated keywords. Bulk-edit across folders. Copy between similar shots.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center text-brand-600 text-xl mb-4">&#x1F4E6;</div>
          <h3 class="font-semibold text-gray-900">Flexible Export</h3>
          <p class="mt-2 text-sm text-gray-600">Export your metadata as CSV in the format each platform expects. Or write metadata back into the image file (IPTC/XMP).</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center text-brand-600 text-xl mb-4">&#x1F512;</div>
          <h3 class="font-semibold text-gray-900">100% Local-First</h3>
          <p class="mt-2 text-sm text-gray-600">Your images never leave your machine. AI runs on your hardware via Ollama. No cloud uploads, no data sharing.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center text-brand-600 text-xl mb-4">&#x2699;&#xFE0F;</div>
          <h3 class="font-semibold text-gray-900">Bring Your Own AI</h3>
          <p class="mt-2 text-sm text-gray-600">Use Ollama for free local inference, or connect any OpenAI-compatible API. You choose the model, the cost, and the quality.</p>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="rounded-xl overflow-hidden shadow-lg border border-gray-200">
          <img src="/features/content-type.png" alt="Content type folder organization — Default, Commercial, Editorial, AI Generated, Illustration" class="w-full" loading="lazy" />
          <div class="p-4 bg-white">
            <h4 class="font-semibold text-gray-900">Content-Type Folders</h4>
            <p class="text-sm text-gray-600 mt-1">Organize by type — each gets the right metadata fields and keyword conventions.</p>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg border border-gray-200">
          <img src="/features/ai-generate.png" alt="AI-generated metadata panel with title, description, and keywords" class="w-full" loading="lazy" />
          <div class="p-4 bg-white">
            <h4 class="font-semibold text-gray-900">AI-Powered Descriptions</h4>
            <p class="text-sm text-gray-600 mt-1">Local AI generates titles, descriptions, and keywords — edit or accept in one click.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-gray-900">Simple pricing</h2>
      <p class="mt-4 text-center text-gray-600">
        Two ways to pay. Same great tool.
      </p>

      <div class="mt-12 max-w-2xl mx-auto">
        <ul class="space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2"><span class="text-brand-600 mt-0.5">&#x2713;</span> AI metadata generation (local Ollama or OpenAI-compatible)</li>
          <li class="flex items-start gap-2"><span class="text-brand-600 mt-0.5">&#x2713;</span> Content-type organization (photo, video, editorial, illustration)</li>
          <li class="flex items-start gap-2"><span class="text-brand-600 mt-0.5">&#x2713;</span> Keyword editor with bulk actions</li>
          <li class="flex items-start gap-2"><span class="text-brand-600 mt-0.5">&#x2713;</span> CSV export in platform-specific formats</li>
          <li class="flex items-start gap-2"><span class="text-brand-600 mt-0.5">&#x2713;</span> IPTC/XMP metadata embedding</li>
          <li class="flex items-start gap-2"><span class="text-brand-600 mt-0.5">&#x2713;</span> Activate on up to 3 devices</li>
          <li class="flex items-start gap-2"><span class="text-brand-600 mt-0.5">&#x2713;</span> 30-day free trial, no credit card</li>
          <li class="flex items-start gap-2"><span class="text-brand-600 mt-0.5">&#x2713;</span> 14-day refund guarantee</li>
        </ul>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <!-- Pro Annual -->
        <div class="rounded-xl border-2 border-brand-600 p-8 relative">
          <div class="absolute -top-3 left-6 bg-brand-600 text-white text-xs font-semibold px-3 py-1 rounded-full">
            Most popular
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Pro Annual</h3>
          <p class="mt-2 text-4xl font-bold text-gray-900">$29.99</p>
          <p class="mt-1 text-sm text-gray-500">per year &middot; cancel anytime</p>
          <a
            href="https://ms-contributor.lemonsqueezy.com/checkout/buy/42b7760e-cd5c-49df-9d8f-f68ebe05e074"
            class="mt-8 block text-center bg-brand-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-brand-700 transition-colors"
          >
            Start Free Trial
          </a>
        </div>

        <!-- Pro Lifetime -->
        <div class="rounded-xl border border-gray-200 p-8 relative">
          <div class="absolute -top-3 left-6 bg-gray-800 text-white text-xs font-semibold px-3 py-1 rounded-full">
            Best value
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Pro Lifetime</h3>
          <p class="mt-2 text-4xl font-bold text-gray-900">$129.99</p>
          <p class="mt-1 text-sm text-gray-500">one-time payment &middot; forever</p>
          <p class="mt-2 text-xs text-gray-400">Pay once, save after ~4.3 years</p>
          <a
            href="https://ms-contributor.lemonsqueezy.com/checkout/buy/f6fba7e0-3bf9-4f46-8cd2-bf53827264f0"
            class="mt-8 block text-center bg-gray-800 text-white px-6 py-3 rounded-lg font-semibold hover:bg-gray-900 transition-colors"
          >
            Buy Lifetime
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
